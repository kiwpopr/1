-- Функция для скачивания файла
function downloadFile(url, savePath)
    local response, code = http.request(url)
    if code == 200 then
        local file = io.open(savePath, "wb")
        file:write(response)
        file:close()
        return true
    else
        print("Ошибка при скачивании файла: " .. code)
        return false
    end
end

